---
import { Image } from 'astro:assets';

// Unique Tier-1 asset for each service — no duplicates
import img19 from '../assets/images/img_19.jpg';   // Maintenance (tending topiary urn)
import img16 from '../assets/images/img_16.jpg';   // Garden Renovations (crew, courtyard)
import img15 from '../assets/images/img_15.jpg';   // Tree & Plant Pruning
import img9  from '../assets/images/img_9.jpg';    // Hedge Management
import img11 from '../assets/images/img_11.jpg';   // Soft Landscaping
import img6  from '../assets/images/img_6.jpg';    // Pest & Disease Control
import img8  from '../assets/images/img_8.jpg';    // Instant Lawn & Turf
import img25 from '../assets/images/img_25.jpg';   // Pressure Cleaning (real asset)
import img7  from '../assets/images/img_7.jpg';    // Green-Waste Removal (lush clean path)
// ↑ img_7 replaces the duplicate img_16 for Green-Waste

// Featured 10th service — Garden Makeovers (full-width card)
import img20 from '../assets/images/img_20.jpg';   // Pre-sale / Makeovers (wisteria kerb appeal)

const services = [
  {
    title: 'Scheduled Garden Maintenance',
    body:  'Reliable, seasonally-tuned care that keeps your garden healthy and immaculate year-round — pruning, feeding, weeding and the watchful eye of people who know plants.',
    img:   img19,
    alt:   "Leo's team member tending a sculpted topiary ball in a French urn beside a pool in a formal garden",
    href:  '/services#maintenance',
  },
  {
    title: 'Garden Renovations',
    body:  'Tired or overgrown spaces reimagined and rebuilt — thoughtful design, the right plants, and a garden that thrives for years to come.',
    img:   img16,
    alt:   'Two crew members working a courtyard — one on a ladder pruning a Japanese maple, one carrying a large shrub',
    href:  '/services#renovations',
  },
  {
    title: 'Tree & Plant Pruning',
    body:  'Precise, species-aware pruning that improves health, structure and form — from fruit trees to feature specimens.',
    img:   img15,
    alt:   'Team member using a long-reach pole hedge-trimmer on a tall leafy hedge wall',
    href:  '/services#pruning',
  },
  {
    title: 'Specialised Hedge Management',
    body:  'Crisp, considered hedging — hand-sheared or machine-cut — for formal lines and lasting density.',
    img:   img9,
    alt:   'Gloved hands using a STIHL HSA 66 battery hedge trimmer on a formal hedge, clippings flying',
    href:  '/services#hedge-management',
  },
  {
    title: 'Soft Landscaping & Planting',
    body:  'Expert plant selection, design and planting that turns a garden into a living, balanced sanctuary.',
    img:   img11,
    alt:   'Two crew members kneeling, hand-planting a garden bed beside a brick border on a green lawn',
    href:  '/services#planting',
  },
  {
    title: 'Pest & Disease Control',
    body:  'Eco-friendly, natural-first treatment that protects your plants and the beneficial life around them.',
    img:   img6,
    alt:   'Spray wand misting a lush garden bed — pest and disease treatment in action',
    href:  '/services#pest-control',
  },
  {
    title: 'Instant Lawn & Turf',
    body:  'Lush, resilient lawns properly prepared and laid — partnered with one of Australia\'s best turf suppliers, Lillydale Instant Lawn.',
    img:   img8,
    alt:   'Manicured parterre lawn in front of a grand classical Melbourne mansion with box-hedge borders',
    href:  '/services#turf',
  },
  {
    title: 'Pressure Cleaning',
    body:  'Paths, patios and driveways restored — powerful, surface-safe cleaning that brings back the kerb appeal instantly.',
    img:   img25,
    alt:   'Pressure-washer wand cleaning a bluestone path surrounded by purple and orange flowering garden beds',
    href:  '/services#pressure-cleaning',
  },
  {
    title: 'Green-Waste & Rubbish Removal',
    body:  'Fast, tidy, eco-conscious clearing of garden waste and bulky items — your space left clean and clutter-free.',
    img:   img7,
    alt:   'Lush vertical garden path — the kind of clean, open space left after professional green-waste clearing',
    href:  '/services#waste-removal',
  },
];

// Featured 10th service — displayed as a full-width editorial strip below the 3×3 grid
const featuredService = {
  title: 'Garden Makeovers & Pre-Sale Preparation',
  body:  'Auction-ready gardens that lift kerb appeal and sale price — we work with homeowners and agents from photography day to auction. From a single-day tidy to a full seasonal renewal, your garden will look its absolute best on the day that matters most.',
  img:   img20,
  alt:   'Wisteria climbing a rendered period home beside clipped box hedging and a gravel path — pristine kerb appeal',
  href:  '/services#pre-sale',
};
---

<section
  id="services"
  class="py-20 md:py-section bg-background"
  aria-labelledby="services-heading"
>
  <div class="max-w-container mx-auto px-6 md:px-10">

    <!-- Section header -->
    <div class="max-w-2xl mb-14 service-reveal">
      <p class="font-display font-normal text-[0.68rem] tracking-[0.28em] uppercase text-text-muted mb-4">
        What We Do
      </p>
      <h2
        id="services-heading"
        class="font-display text-heading-xl text-text-base leading-tight"
      >
        Every garden has<br class="hidden md:block" /> a different story.<br class="hidden md:block" />
        We know how to read them.
      </h2>
    </div>

    <!-- ── 9-card grid (3 × 3 on desktop) ──────────────────────────── -->
    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6 list-none m-0 p-0 mb-5 md:mb-6">
      {services.map((s, i) => (
        <li
          class="service-reveal bg-surface rounded-brand-lg overflow-hidden shadow-brand hover:shadow-brand-lg hover:-translate-y-1.5 transition-all duration-300 motion-reduce:transition-none cursor-pointer group"
          style={`transition-delay: ${(i % 3) * 70}ms`}
        >
          <!-- Card image — fixed 4:3 ratio, consistent across all cards -->
          <div class="aspect-[4/3] overflow-hidden">
            <Image
              src={s.img}
              alt={s.alt}
              width={800}
              height={600}
              quality={85}
              class="w-full h-full object-cover transition-transform duration-600 group-hover:scale-[1.05] motion-reduce:transition-none"
              loading="lazy"
            />
          </div>
          <!-- Card body -->
          <div class="p-6 space-y-2">
            <h3 class="font-display text-heading-md text-text-base">{s.title}</h3>
            <p class="font-body text-body-sm text-text-muted leading-relaxed">{s.body}</p>
            <a
              href={s.href}
              class="inline-flex items-center gap-1.5 pt-2 font-body font-semibold text-body-sm text-accent hover:text-accent-600 transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2 rounded-sm"
              aria-label={`Learn more about ${s.title}`}
            >
              Learn more
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </a>
          </div>
        </li>
      ))}
    </ul>

    <!-- ── Featured 10th service — full-width editorial card ─────────
         Prevents the awkward single-card orphan in the grid.
         Gives the flagship "Pre-Sale Prep" service a premium spotlight.
    ────────────────────────────────────────────────────────────────── -->
    <div
      class="service-reveal bg-primary rounded-brand-lg overflow-hidden shadow-brand-lg group cursor-pointer hover:shadow-[0_24px_60px_-16px_rgba(31,42,26,0.28)] transition-shadow duration-400"
      style="transition-delay: 100ms"
    >
      <div class="grid grid-cols-1 md:grid-cols-2 min-h-[320px] md:min-h-[360px]">

        <!-- Image — left on desktop, top on mobile -->
        <div class="relative overflow-hidden min-h-[220px] md:min-h-0">
          <Image
            src={featuredService.img}
            alt={featuredService.alt}
            width={900}
            height={600}
            quality={88}
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.04] motion-reduce:transition-none"
            loading="lazy"
          />
          <!-- Subtle right-edge blend into the green text panel -->
          <div class="absolute inset-y-0 right-0 w-16 md:w-24 bg-gradient-to-r from-transparent to-primary hidden md:block" aria-hidden="true"></div>
        </div>

        <!-- Text panel — right on desktop -->
        <div class="flex flex-col justify-center px-8 md:px-12 py-10 space-y-5">
          <p class="font-display font-normal text-[0.65rem] tracking-[0.28em] uppercase text-secondary-400">
            Signature Service
          </p>
          <h3 class="font-display text-heading-xl text-surface leading-tight">
            {featuredService.title}
          </h3>
          <p class="font-body text-body-md text-secondary-200 leading-relaxed">
            {featuredService.body}
          </p>
          <a
            href={featuredService.href}
            class="inline-flex items-center gap-2 font-display font-normal text-[0.72rem] tracking-[0.15em] uppercase text-accent hover:text-accent-400 transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2 rounded-sm group/link"
            aria-label={`Learn more about ${featuredService.title}`}
          >
            Learn more
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="transition-transform duration-200 group-hover/link:translate-x-1">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
        </div>

      </div>
    </div>

  </div>
</section>

<script>
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReduced) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const delay = el.style.transitionDelay || '0ms';
            el.style.transition = `opacity 650ms ease-out ${delay}, transform 650ms ease-out ${delay}`;
            el.style.opacity   = '1';
            el.style.transform = 'translateY(0)';
            io.unobserve(el);
          }
        });
      },
      { threshold: 0.08 }
    );
    document.querySelectorAll<HTMLElement>('.service-reveal').forEach(el => {
      el.style.opacity   = '0';
      el.style.transform = 'translateY(20px)';
      io.observe(el);
    });
  }
</script>
