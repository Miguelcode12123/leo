---
import { Image } from 'astro:assets';
import img13 from '../assets/images/img_13.jpg';
---

<!-- Warm image band above the form -->
<div class="relative h-56 md:h-72 overflow-hidden">
  <Image
    src={img13}
    alt="Romantic heritage courtyard garden — wrought-iron bench, ferns in aged pots, stone chequerboard paving and an ivy-arched doorway"
    width={1920}
    height={576}
    class="absolute inset-0 w-full h-full object-cover object-center"
    loading="lazy"
  />
  <div class="absolute inset-0 bg-primary-900/50" aria-hidden="true"></div>
</div>

<!-- Contact CTA section -->
<section
  id="contact"
  class="bg-primary py-20 md:py-section-lg"
  aria-labelledby="contact-heading"
>
  <div class="max-w-container mx-auto px-6 md:px-10">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 items-start">

      <!-- Left: invitation + details -->
      <div class="space-y-6 contact-reveal text-secondary-100">
        <p class="font-display font-normal text-[0.68rem] tracking-[0.28em] uppercase text-secondary-400">Get in touch</p>
        <h2
          id="contact-heading"
          class="font-display text-display-lg text-surface"
        >
          Let's grow something beautiful together.
        </h2>
        <p class="font-body text-body-lg text-secondary-200 leading-relaxed">
          Tell us a little about your garden and we'll be in touch to arrange a free,
          no-obligation quote.
        </p>

        <div class="space-y-4 pt-2">

          <!-- Phone -->
          <a
            href="tel:+61449915712"
            class="flex items-center gap-3 group cursor-pointer"
            aria-label="Call us on 0449 915 712"
          >
            <span class="w-10 h-10 rounded-full bg-primary-600 flex items-center justify-center flex-shrink-0 group-hover:bg-accent transition-colors duration-200 motion-reduce:transition-none" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                   fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.59 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </span>
            <div>
              <p class="font-body font-semibold text-body-md text-surface group-hover:text-secondary-100 transition-colors duration-200 motion-reduce:transition-none">0449 915 712</p>
              <p class="font-body text-body-sm text-secondary-300">Call or text anytime</p>
            </div>
          </a>

          <!-- Email -->
          <a
            href="mailto:bookings@leosgardens.com.au"
            class="flex items-center gap-3 group cursor-pointer"
            aria-label="Email us at bookings@leosgardens.com.au"
          >
            <span class="w-10 h-10 rounded-full bg-primary-600 flex items-center justify-center flex-shrink-0 group-hover:bg-accent transition-colors duration-200 motion-reduce:transition-none" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                   fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
            </span>
            <div>
              <p class="font-body font-semibold text-body-md text-surface group-hover:text-secondary-100 transition-colors duration-200 motion-reduce:transition-none">bookings@leosgardens.com.au</p>
              <p class="font-body text-body-sm text-secondary-300">We reply within one business day</p>
            </div>
          </a>

          <!-- Service area -->
          <div class="flex items-center gap-3">
            <span class="w-10 h-10 rounded-full bg-primary-600 flex items-center justify-center flex-shrink-0" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                   fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
              </svg>
            </span>
            <div>
              <p class="font-body font-semibold text-body-md text-surface">Armadale · Toorak · Malvern · Brighton · Hawthorn</p>
              <p class="font-body text-body-sm text-secondary-300">All Melbourne inner south-east &amp; Mornington Peninsula</p>
            </div>
          </div>

          <!-- Hours placeholder -->
          <div class="flex items-center gap-3">
            <span class="w-10 h-10 rounded-full bg-primary-600 flex items-center justify-center flex-shrink-0" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                   fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
            </span>
            <div>
              <p class="font-body font-semibold text-body-md text-surface">
                <!-- client to confirm hours -->
                Mon – Sat, 7 am – 5 pm
              </p>
              <p class="font-body text-body-sm text-secondary-300">Free quotes — no obligation</p>
            </div>
          </div>

        </div>
      </div>

      <!-- Right: quote form -->
      <div class="contact-reveal" style="transition-delay: 150ms">
        <div class="bg-surface rounded-brand-lg p-8 shadow-brand-lg">
          <h3 class="font-display text-heading-lg text-text-base mb-6">Request a free quote</h3>

          <!--
            FORM ACTION — placeholder for client's handler.
            Replace `action` attribute with Formspree / Netlify Forms / your endpoint.
            Example Formspree: action="https://formspree.io/f/YOUR_FORM_ID"
          -->
          <form
            method="POST"
            action="#contact"
            class="space-y-5"
            novalidate
            id="quote-form"
          >
            <!-- First name -->
            <div>
              <label
                for="fname"
                class="block font-body font-semibold text-body-sm text-text-base mb-1.5"
              >First name</label>
              <input
                type="text"
                id="fname"
                name="first_name"
                autocomplete="given-name"
                required
                class="w-full rounded-brand border border-border bg-background px-4 py-3 font-body text-body-md text-text-base placeholder-text-muted focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors duration-200 motion-reduce:transition-none"
                placeholder="Your first name"
              />
            </div>

            <!-- Email -->
            <div>
              <label
                for="email"
                class="block font-body font-semibold text-body-sm text-text-base mb-1.5"
              >Email <span class="text-accent" aria-label="required">*</span></label>
              <input
                type="email"
                id="email"
                name="email"
                autocomplete="email"
                required
                class="w-full rounded-brand border border-border bg-background px-4 py-3 font-body text-body-md text-text-base placeholder-text-muted focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors duration-200 motion-reduce:transition-none"
                placeholder="your@email.com"
              />
            </div>

            <!-- Phone -->
            <div>
              <label
                for="phone"
                class="block font-body font-semibold text-body-sm text-text-base mb-1.5"
              >Phone</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                autocomplete="tel"
                class="w-full rounded-brand border border-border bg-background px-4 py-3 font-body text-body-md text-text-base placeholder-text-muted focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors duration-200 motion-reduce:transition-none"
                placeholder="0400 000 000"
              />
            </div>

            <!-- Suburb -->
            <div>
              <label
                for="suburb"
                class="block font-body font-semibold text-body-sm text-text-base mb-1.5"
              >Suburb</label>
              <input
                type="text"
                id="suburb"
                name="suburb"
                class="w-full rounded-brand border border-border bg-background px-4 py-3 font-body text-body-md text-text-base placeholder-text-muted focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors duration-200 motion-reduce:transition-none"
                placeholder="e.g. Armadale"
              />
            </div>

            <!-- Message -->
            <div>
              <label
                for="message"
                class="block font-body font-semibold text-body-sm text-text-base mb-1.5"
              >About your garden</label>
              <textarea
                id="message"
                name="message"
                rows="4"
                class="w-full rounded-brand border border-border bg-background px-4 py-3 font-body text-body-md text-text-base placeholder-text-muted focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors duration-200 motion-reduce:transition-none resize-none"
                placeholder="Tell us a little about your garden and what you're looking for…"
              ></textarea>
            </div>

            <!-- Submit -->
            <button
              type="submit"
              class="w-full rounded-pill bg-accent text-surface px-6 py-4 font-body font-semibold text-body-md hover:bg-accent-600 active:bg-accent-700 transition-colors duration-200 motion-reduce:transition-none focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2 cursor-pointer"
            >
              Request my free quote
            </button>

            <p class="font-body text-body-sm text-text-muted text-center">
              No obligation. We'll be in touch within one business day.
            </p>
          </form>

          <!-- Success state (hidden by default) -->
          <div
            id="form-success"
            class="hidden text-center py-8 space-y-3"
            aria-live="polite"
          >
            <div class="w-14 h-14 rounded-full bg-primary-100 flex items-center justify-center mx-auto" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24"
                   fill="none" stroke="#2E4628" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 6 9 17l-5-5"/>
              </svg>
            </div>
            <p class="font-display text-heading-md text-text-base">Thank you — we'll be in touch shortly.</p>
            <p class="font-body text-body-sm text-text-muted">We look forward to seeing your garden.</p>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReduced) {
    const io = new IntersectionObserver(
      entries => entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const delay = el.style.transitionDelay || '0ms';
          el.style.transition = `opacity 600ms ease-out ${delay}, transform 600ms ease-out ${delay}`;
          el.style.opacity   = '1';
          el.style.transform = 'translateY(0)';
          io.unobserve(el);
        }
      }),
      { threshold: 0.12 }
    );
    document.querySelectorAll<HTMLElement>('.contact-reveal').forEach(el => {
      el.style.opacity   = '0';
      el.style.transform = 'translateY(16px)';
      io.observe(el);
    });
  }
</script>
