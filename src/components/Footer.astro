---
import { Image } from 'astro:assets';
import logo4 from '../assets/images/logo_4.png';
import logo1 from '../assets/images/logo_1.png';

const year = new Date().getFullYear();

const quickLinks = [
  { label: 'Home',       href: '/'             },
  { label: 'Services',   href: '/services'     },
  { label: 'Gallery',    href: '/gallery'      },
  { label: 'About',      href: '/about'        },
  { label: 'Contact',    href: '/contact'      },
  { label: 'Get a Free Quote', href: '#contact' },
];

const serviceLinks = [
  { label: 'Scheduled Maintenance', href: '/services#maintenance'        },
  { label: 'Garden Renovations',    href: '/services#renovations'        },
  { label: 'Tree & Plant Pruning',  href: '/services#pruning'            },
  { label: 'Hedge Management',      href: '/services#hedge-management'   },
  { label: 'Soft Landscaping',      href: '/services#planting'           },
  { label: 'Pressure Cleaning',     href: '/services#pressure-cleaning'  },
  { label: 'Pre-Sale Prep',         href: '/services#pre-sale'           },
];
---

<footer class="bg-primary-900 text-secondary-200" aria-label="Site footer">

  <!-- Main footer grid -->
  <div class="max-w-container mx-auto px-6 md:px-10 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-10 md:gap-8">

      <!-- Column 1: Logo + tagline + "SINCE 2021" crest -->
      <div class="space-y-5 sm:col-span-2 md:col-span-1">
        <a
          href="/"
          class="inline-block focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-4 rounded-brand"
          aria-label="Leo's Beautiful Gardens — return to home page"
        >
          <Image
            src={logo4}
            alt="Leo's Beautiful Gardens round emblem — cream running gardener on forest green"
            height={64}
            class="h-16 w-auto"
            loading="lazy"
          />
        </a>
        <p class="font-body text-body-sm text-secondary-300 leading-relaxed max-w-[220px]">
          Garden care as craft.<br />Melbourne.
        </p>
        <!-- SINCE 2021 · VICTORIA crest — credential stamp -->
        <Image
          src={logo1}
          alt="Leo's Beautiful Gardens — Since 2021, Victoria — credential crest"
          height={56}
          class="h-14 w-auto opacity-60"
          loading="lazy"
        />
      </div>

      <!-- Column 2: Quick links -->
      <nav aria-label="Quick links">
        <p class="font-body text-label text-secondary-400 tracking-widest uppercase mb-5">Navigate</p>
        <ul class="space-y-3 list-none m-0 p-0">
          {quickLinks.map(({ label, href }) => (
            <li>
              <a
                href={href}
                class="font-body text-body-sm text-secondary-200 hover:text-surface transition-colors duration-200 motion-reduce:transition-none focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2 rounded-sm"
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Column 3: Services -->
      <nav aria-label="Services">
        <p class="font-body text-label text-secondary-400 tracking-widest uppercase mb-5">Services</p>
        <ul class="space-y-3 list-none m-0 p-0">
          {serviceLinks.map(({ label, href }) => (
            <li>
              <a
                href={href}
                class="font-body text-body-sm text-secondary-200 hover:text-surface transition-colors duration-200 motion-reduce:transition-none focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2 rounded-sm"
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Column 4: Contact + Instagram -->
      <div class="space-y-5">
        <p class="font-body text-label text-secondary-400 tracking-widest uppercase">Contact</p>
        <ul class="space-y-3 list-none m-0 p-0">
          <li>
            <a
              href="tel:+61449915712"
              class="font-body text-body-sm text-secondary-200 hover:text-surface transition-colors duration-200 motion-reduce:transition-none focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2 rounded-sm"
              aria-label="Call 0449 915 712"
            >
              0449 915 712
            </a>
          </li>
          <li>
            <a
              href="mailto:bookings@leosgardens.com.au"
              class="font-body text-body-sm text-secondary-200 hover:text-surface transition-colors duration-200 motion-reduce:transition-none focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2 rounded-sm"
            >
              bookings@leosgardens.com.au
            </a>
          </li>
          <li class="font-body text-body-sm text-secondary-300">
            Armadale · Toorak · Malvern<br />Brighton · Mornington Peninsula
          </li>
        </ul>

        <!-- Instagram -->
        <a
          href="https://www.instagram.com/leos_beautiful_gardens/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 font-body text-body-sm text-secondary-300 hover:text-accent transition-colors duration-200 motion-reduce:transition-none focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2 rounded-sm"
          aria-label="Follow Leo's Beautiful Gardens on Instagram (opens in new tab)"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
          </svg>
          @leos_beautiful_gardens
        </a>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-primary-800">
    <div class="max-w-container mx-auto px-6 md:px-10 py-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-secondary-400">
      <p class="font-body text-body-sm">
        © {year} Leo's Beautiful Gardens. All rights reserved.
      </p>
      <p class="font-body text-body-sm">
        ABN: <span class="text-secondary-300">[client to supply]</span> · Melbourne, VIC, Australia
      </p>
    </div>
  </div>

</footer>
