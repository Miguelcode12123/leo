---
/**
 * Nav.astro — Leo's Beautiful Gardens
 *
 * ─── Philosophy ───────────────────────────────────────────────────────────────
 *  The nav references the exact two-tone palette of the brand emblem (img_2):
 *  cream ground + forest green figure.
 *
 *  Pre-scroll  : warm cream frosted glass (bg-background/90 backdrop-blur-md)
 *                — matches the cream of the emblem. All elements dark forest green.
 *                  The circular logo pops beautifully: its own green ground on cream.
 *  Post-scroll : deep forest green (bg-primary-900/97) — nav inverts.
 *                  All elements cream, CTA blooms terracotta.
 *  Inner pages : always post-scroll state (transparent=false).
 *
 * ─── Layout ───────────────────────────────────────────────────────────────────
 *  Desktop  →  [≡]  ·········LOGO (absolute centre)·········  [Book a Consultation]
 *  Mobile   →  [≡]  ·········LOGO (equal-flex centred)·······  [spacer]
 *
 * ─── Logo ─────────────────────────────────────────────────────────────────────
 *  img_2 cropped to a circle. No hover animation — it is the hero element.
 *  ring-1 ring-primary/18 : subtle green ring echoes the brand emblem's own border.
 *
 * ─── Hamburger ────────────────────────────────────────────────────────────────
 *  Three ultra-thin 1px lines. Middle line shorter — editorial asymmetry.
 *  On hover the middle line extends to match. No text label.
 *  Colour responds to the nav state via group-data-[scrolled] Tailwind variant.
 *
 * ─── Full-screen overlay ──────────────────────────────────────────────────────
 *  bg-primary-900, both mobile + desktop.
 *  Links stagger in with a subtle translateY on open.
 */
import { Image } from 'astro:assets';
import logo2 from '../assets/images/logo_2.png';

interface Props {
  transparent?: boolean;
}
const { transparent = true } = Astro.props;

const navLinks = [
  { label: 'Home',     href: '/'         },
  { label: 'Services', href: '/services' },
  { label: 'Gallery',  href: '/gallery'  },
  { label: 'About',    href: '/about'    },
  { label: 'Contact',  href: '/contact'  },
];
---

<!-- ─── Sticky header ──────────────────────────────────────────────────────── -->
<!--
  `group` enables child elements to respond to nav state via
  group-data-[scrolled=true]:* / group-data-[scrolled=false]:* Tailwind variants.
  This drives the hamburger colour inversion without any extra JS.
-->
<header
  id="site-nav"
  data-scrolled={transparent ? "false" : "true"}
  data-transparent={transparent.toString()}
  data-hero-phase={transparent ? "true" : "false"}
  data-gallery-clear="false"
  data-gallery-returning="false"
  data-hidden="false"
  class={[
    'sticky top-0 z-50 w-full group',
    'transition-[background-color,opacity,transform] duration-300 ease-[cubic-bezier(0.22,1,0.36,1)] motion-reduce:transition-none',
    /*
     * Pre-scroll  : warm cream frosted glass — the cream of the brand emblem.
     *               border-border gives a warm sand hairline visible against cream.
     * Post-scroll : deep forest green solid — the green of the brand emblem.
     *               border-white/6 gives a barely-there hairline against dark green.
     */
    transparent
      ? 'bg-background/[0.92] backdrop-blur-md border-b border-border/[0.75]'
      : 'bg-primary-900/[0.97] backdrop-blur-sm border-b border-white/[0.06]',
  ].join(' ')}
>

  <!-- ── Gradient scrim — hero legibility veil (transparent pages only) ─── -->
  {transparent && (
    <div
      id="nav-scrim"
      class="absolute inset-x-0 top-0 h-48
             bg-gradient-to-b from-black/[0.10] via-transparent to-transparent
             pointer-events-none
             transition-opacity duration-500 motion-reduce:transition-none"
      aria-hidden="true"
    ></div>
  )}

  <!-- ─── Inner container (height managed in globals.css via .nav-inner) ─── -->
  <div class="nav-inner relative px-6 sm:px-10 lg:px-14 xl:px-20 flex items-center">

    <!-- ── LEFT: Hamburger ─────────────────────────────────────────────────── -->
    <div class="flex-1 flex items-center">
      <button
        id="menu-toggle"
        type="button"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="site-menu"
        class="flex items-center gap-3 cursor-pointer
               focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-4
               rounded-sm group/ham"
      >
        <!--
          Three ultra-thin 1px lines. Middle line intentionally shorter — editorial asymmetry.
          On hover the middle line extends to full width.

          Colour:
            pre-scroll  (data-scrolled=false) → text-text-base  
            post-scroll (data-scrolled=true)  → text-surface  (cream on dark green bg)

          The parent <header> carries `group`, so group-data-[scrolled=true] fires on the
          nav's own data attribute. Transition-colors runs at the same 500ms as the bg.
        -->
        <span class="flex flex-col justify-center gap-[6px] w-7 h-6 flex-shrink-0" aria-hidden="true">
          <span class="block h-px bg-current w-7
                       transition-[width,color] duration-300 ease-in-out
                       text-text-base
                       motion-reduce:transition-none"></span>
          <span class="block h-px bg-current w-4 group-hover/ham:w-7
                       transition-[width,color] duration-300 ease-in-out origin-left
                       text-text-base
                       motion-reduce:transition-none"></span>
          <span class="block h-px bg-current w-7
                       transition-[width,color] duration-300 ease-in-out
                       text-text-base
                       motion-reduce:transition-none"></span>
        </span>
        <!-- "Menu" label -->
        <span class="font-body font-medium text-[0.92rem] tracking-[0.04em]
                     text-text-base
                     transition-colors duration-300 motion-reduce:transition-none"
              aria-hidden="true">
          Menu
        </span>
      </button>
    </div>

    <!-- ── CENTRE: Logo ───────────────────────────────────────────────────── -->

    <!-- Desktop: absolute centre — independent of left/right element widths -->
    <div class="hidden lg:flex absolute left-1/2 -translate-x-1/2 pointer-events-auto">
      <a
        href="/"
        aria-label="Leo's Beautiful Gardens — return to home page"
        class="focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-4 rounded-sm"
      >
        <div class="nav-logo-desktop flex-shrink-0">
          <Image
            src={logo2}
            alt="Leo's Beautiful Gardens logo"
            width={512}
            height={512}
            quality={95}
            densities={[1, 2, 3]}
            class="h-full w-auto block"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </a>
    </div>

    <!-- Mobile: natural flex position between two equal flex-1 divs → centred -->
    <a
      href="/"
      aria-label="Leo's Beautiful Gardens — return to home page"
      class="lg:hidden focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-4 rounded-sm"
    >
      <div class="nav-logo-mobile h-12 flex-shrink-0">
        <Image
          src={logo2}
          alt="Leo's Beautiful Gardens logo"
          width={512}
          height={512}
          quality={95}
          densities={[1, 2, 3]}
          class="h-full w-auto block"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </a>

    <!-- ── RIGHT: CTA (desktop) / invisible spacer (mobile) ──────────────── -->
    <div class="flex-1 flex items-center justify-end">
      <!--
        Desktop CTA.
        Two visual states — JS swaps the colour classes in syncScrollState():

        Pre-scroll (cream bg)  → dark green ghost pill: references the forest green
                                 in the logo, completes the two-tone palette.
        Post-scroll (green bg) → terracotta filled pill: accent pops against dark green.

        The structural classes (shape, font, size, transitions) never change.
      -->
      <!--
        Editorial text link — no pill, pure typography.
        Matches the "Menu" label style on the left (same font, size, tracking, uppercase)
        creating a visual bookend. Hover: terracotta colour + arrow slides right + 1px
        underline grows from left via scaleX (GPU-composited, smooth).
      -->
      <a
        href="#contact"
        id="nav-cta"
        class={[
          'hidden lg:inline-flex items-center gap-2.5 relative group/cta cursor-pointer',
          'font-body font-medium text-[0.92rem] tracking-[0.04em] whitespace-nowrap',
          'text-text-base hover:text-accent',
          'transition-colors duration-300 motion-reduce:transition-none',
          'focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-4',
        ].join(' ')}
      >
        Book a Consultation
        <!-- Arrow slides right 3px on hover -->
        <span
          class="inline-block transition-transform duration-300 ease-out
                 group-hover/cta:translate-x-[3px]
                 motion-reduce:transition-none"
          aria-hidden="true"
        >→</span>
        <!-- 1px underline grows from left to right on hover -->
        <span
          class="absolute inset-x-0 bottom-[-3px] h-px bg-current
                 scale-x-0 origin-left group-hover/cta:scale-x-100
                 transition-transform duration-300 ease-out
                 motion-reduce:transition-none"
          aria-hidden="true"
        ></span>
      </a>

      <!-- Mobile spacer — mirrors hamburger width to keep logo centred -->
      <div class="lg:hidden w-7 h-6 flex-shrink-0" aria-hidden="true"></div>
    </div>

  </div>
</header>


<!-- ─── Full-screen overlay ───────────────────────────────────────────────────
  Layout:
  Mobile  → single column (large links, bottom CTA + phone)
  Desktop → two columns (large Fraunces links left; contact + CTA right)
──────────────────────────────────────────────────────────────────────────── -->
<div
  id="site-menu"
  role="dialog"
  aria-label="Site navigation"
  aria-modal="true"
  aria-hidden="true"
  data-open="false"
  data-lenis-prevent
  class="fixed inset-0 z-[100] bg-primary-900 flex flex-col overflow-y-auto
         opacity-0 pointer-events-none
         transition-opacity duration-[350ms] motion-reduce:transition-none
         data-[open=true]:opacity-100 data-[open=true]:pointer-events-auto"
>

  <!-- ── Overlay header ─────────────────────────────────────────────────── -->
  <div class="flex-shrink-0 flex items-center h-20 md:h-24
              px-6 sm:px-10 mx-auto max-w-container w-full relative">

    <!-- Close button -->
    <div class="flex-1 flex items-center">
      <button
        id="menu-close"
        type="button"
        aria-label="Close navigation menu"
        class="flex items-center gap-2.5 cursor-pointer
               focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-4
               rounded-sm text-surface/65 hover:text-surface transition-colors duration-200"
      >
        <span class="relative w-6 h-5 flex-shrink-0" aria-hidden="true">
          <span class="absolute inset-x-0 top-1/2 h-px bg-current rotate-45"></span>
          <span class="absolute inset-x-0 top-1/2 h-px bg-current -rotate-45"></span>
        </span>
        <span class="hidden lg:block font-body font-medium text-[0.72rem] tracking-[0.2em] uppercase">
          Close
        </span>
      </button>
    </div>

    <!-- Logo — mirrors nav centre position -->
    <a
      href="/"
      aria-label="Leo's Beautiful Gardens — return to home page"
      class="absolute left-1/2 -translate-x-1/2
             focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-4 rounded-sm"
    >
      <div class="h-12 md:h-14 flex-shrink-0">
        <Image
          src={logo2}
          alt="Leo's Beautiful Gardens logo"
          width={512}
          height={512}
          quality={95}
          densities={[1, 2, 3]}
          class="h-full w-auto block"
          loading="lazy"
        />
      </div>
    </a>

    <div class="flex-1" aria-hidden="true"></div>
  </div>


  <!-- ── Main content ──────────────────────────────────────────────────────── -->
  <div class="flex-1 flex flex-col lg:flex-row mx-auto max-w-container w-full
              px-8 sm:px-12 lg:px-16 xl:px-20
              pt-6 lg:pt-0 lg:items-center
              gap-0 lg:gap-16 xl:gap-24">

    <!-- Navigation links -->
    <nav class="flex flex-col flex-1 lg:justify-center" aria-label="Full navigation">
      {navLinks.map(({ label, href }) => (
        <a
          href={href}
          class={[
            'menu-nav-link',
            'font-display font-normal',
            'text-surface/55 hover:text-surface',
            'text-[2.75rem] md:text-[3.5rem] lg:text-[4.25rem] xl:text-[5rem] leading-none',
            'tracking-[-0.01em]',
            'relative inline-block py-[0.4em]',
            'after:content-[\'\'] after:absolute after:bottom-[0.35em] after:left-0 after:right-0',
            'after:h-px after:bg-current after:opacity-0 hover:after:opacity-25',
            'after:transition-opacity after:duration-200 motion-reduce:after:transition-none',
            'transition-colors duration-200 motion-reduce:transition-none',
            'border-b border-primary-700/35 last:border-b-0',
            'focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-4',
          ].join(' ')}
        >
          {label}
        </a>
      ))}

      <p class="hidden lg:block font-display italic text-secondary-500/80 text-[0.88rem] tracking-[0.05em] mt-10">
        Coltivato con cura.
      </p>
    </nav>


    <!-- ── Desktop right column ──────────────────────────────────────────── -->
    <aside
      class="hidden lg:flex flex-col justify-center
             w-72 xl:w-80 flex-shrink-0
             border-l border-primary-700/45
             pl-12 xl:pl-16 gap-8"
    >
      <a
        href="#contact"
        class="inline-flex items-center justify-center rounded-pill
               bg-accent text-surface
               px-6 py-[0.75rem]
               font-body font-semibold text-[0.8rem] tracking-[0.09em]
               hover:bg-accent-600 transition-colors duration-200
               cursor-pointer w-full
               focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-4"
      >
        Book a Consultation
      </a>

      <div class="space-y-4">
        <a href="tel:+61449915712" class="flex items-center gap-3 group/phone" aria-label="Call 0449 915 712">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
               class="text-secondary-500 flex-shrink-0" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.59 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          <span class="font-body font-medium text-body-sm text-secondary-300 group-hover/phone:text-surface transition-colors duration-200">0449 915 712</span>
        </a>

        <a href="mailto:bookings@leosgardens.com.au" class="flex items-center gap-3 group/email" aria-label="Email bookings@leosgardens.com.au">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
               class="text-secondary-500 flex-shrink-0" aria-hidden="true">
            <rect width="20" height="16" x="2" y="4" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
          <span class="font-body font-medium text-body-sm text-secondary-300 group-hover/email:text-surface transition-colors duration-200 break-all">bookings@leosgardens.com.au</span>
        </a>

        <div class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
               class="text-secondary-500 flex-shrink-0" aria-hidden="true">
            <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          <span class="font-body text-body-sm text-secondary-400">All Melbourne · Mornington Peninsula</span>
        </div>
      </div>

      <div class="pt-2 border-t border-primary-700/45">
        <p class="font-display italic text-secondary-600 text-[0.8rem] tracking-[0.04em]">Coltivato con cura.</p>
      </div>
    </aside>
  </div>


  <!-- ── Mobile bottom bar ────────────────────────────────────────────────── -->
  <div class="lg:hidden flex-shrink-0 px-8 pb-12 pt-6 space-y-4">
    <a
      href="#contact"
      class="block text-center rounded-pill bg-accent text-surface
             px-5 py-4 font-body font-semibold text-body-md tracking-wide
             hover:bg-accent-600 transition-colors duration-200
             focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-4
             cursor-pointer"
    >
      Book a Consultation
    </a>
    <a
      href="tel:+61449915712"
      class="block text-center font-body font-medium text-body-sm text-secondary-400 hover:text-surface transition-colors duration-200 py-2"
      aria-label="Call 0449 915 712"
    >
      0449&nbsp;915&nbsp;712
    </a>
  </div>

</div><!-- /site-menu -->


<script>
  import { debounce } from '../utils/debounce';
  import { registerScrollFrame, scheduleScrollFrame } from '../utils/scrollFrame';

  /* ─── Element refs ────────────────────────────────────────────────────────── */
  const nav         = document.getElementById('site-nav')     as HTMLElement | null;
  const scrim       = document.getElementById('nav-scrim')    as HTMLElement | null;
  const cta         = document.getElementById('nav-cta')      as HTMLElement | null;
  const overlay     = document.getElementById('site-menu')    as HTMLElement | null;
  const toggleBtn   = document.getElementById('menu-toggle')  as HTMLButtonElement | null;
  const closeBtn    = document.getElementById('menu-close')   as HTMLButtonElement | null;
  const heroWrapper = document.getElementById('hero-wrapper') as HTMLElement | null;
  const hiddenRegions = Array.from(
    document.querySelectorAll<HTMLElement>('[data-nav-hidden-region]')
  );

  const isTransparent  = nav?.dataset.transparent === 'true';
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  let cachedHeroScrollEnd = heroWrapper
    ? Math.max(0, heroWrapper.offsetHeight - window.innerHeight)
    : 0;
  let hiddenRegionBounds: Array<{ top: number; end: number }> = [];

  /* ─── syncScrollState ────────────────────────────────────────────────────── */
  /**
   * Three-state nav machine:
   *
   *   full-size   (data-hero-phase="true", data-scrolled="false")
   *     ↳ Transparent background, expanded nav height.
   *       Active until the same threshold that triggers shrinking.
   *
   *   compact     (data-hero-phase="false", data-scrolled="true")
   *     ↳ Cream background, compact (5rem). Normal scrolled state.
   *
   *   gallery hidden region (data-gallery-clear="true", data-hidden="true")
   *     ↳ Nav chrome clears first, then the nav content fades/lifts out.
   *
   * heroScrollEnd = hero wrapper's offsetHeight − window.innerHeight.
   * Wrapper height = scrollHeight prop + 100vh → heroScrollEnd = scrollHeight (e.g. 1500px).
   */
  function cacheHiddenRegionBounds(): void {
    const scrollY = window.scrollY;

    hiddenRegionBounds = hiddenRegions.map((region) => {
      const rect = region.getBoundingClientRect();
      const top = scrollY + rect.top;
      const end = Math.max(top, top + region.offsetHeight - window.innerHeight);

      return { top, end };
    });
  }

  function isInHiddenRegion(): boolean {
    const scrollY = window.scrollY;

    return hiddenRegionBounds.some(({ top, end }) => {
      return scrollY >= top && scrollY <= end;
    });
  }

  let galleryNavConcealed = false;
  let galleryClearTimer = 0;
  let galleryHideTimer = 0;
  let galleryReturnTimer = 0;
  const galleryHideDelay = 260;
  const galleryRevealDelay = 360;

  function setGalleryNavConcealed(shouldConceal: boolean): void {
    if (!nav || galleryNavConcealed === shouldConceal) return;

    galleryNavConcealed = shouldConceal;
    window.clearTimeout(galleryClearTimer);
    window.clearTimeout(galleryHideTimer);
    window.clearTimeout(galleryReturnTimer);

    if (shouldConceal) {
      nav.dataset.galleryReturning = 'false';
      nav.dataset.galleryClear = 'true';
      galleryHideTimer = window.setTimeout(() => {
        nav.dataset.hidden = 'true';
      }, galleryHideDelay);
      return;
    }

    nav.dataset.galleryReturning = 'true';
    nav.dataset.galleryClear = 'false';
    galleryClearTimer = window.setTimeout(() => {
      nav.dataset.hidden = 'false';
    }, galleryRevealDelay);
    galleryReturnTimer = window.setTimeout(() => {
      nav.dataset.galleryReturning = 'false';
    }, galleryRevealDelay + 520);
  }

  type NavScrollState = {
    inHeroPhase: boolean;
    inHiddenRegion: boolean;
    shouldShrink: boolean;
  };

  function readNavScrollState(): NavScrollState {
    const threshold = cachedHeroScrollEnd > 0 ? cachedHeroScrollEnd + 60 : 80;
    const shouldShrink = isTransparent ? window.scrollY > threshold : true;
    const inHeroPhase = isTransparent && !shouldShrink;
    const inHiddenRegion = isTransparent && shouldShrink && isInHiddenRegion();

    return { inHeroPhase, inHiddenRegion, shouldShrink };
  }

  function writeNavScrollState(state: NavScrollState): void {
    if (!nav) return;

    setGalleryNavConcealed(state.inHiddenRegion);
    nav.dataset.heroPhase = state.inHeroPhase ? 'true' : 'false';
    nav.dataset.scrolled = state.inHeroPhase ? 'false' : (state.shouldShrink ? 'true' : 'false');

    if (scrim) {
      scrim.style.opacity = state.inHeroPhase || state.shouldShrink ? '0' : '1';
    }
  }

  // rAF guarantees layout is complete before first check — heroWrapper.offsetHeight is
  // correct, so heroPhase never flickers "false" and triggers a stray cream-in transition.
  // The initial HTML already has data-hero-phase set correctly for scrollY=0, so
  // there is no visible gap on first paint.
  if (isTransparent) {
    cacheHiddenRegionBounds();
    registerScrollFrame({
      read: readNavScrollState,
      write: writeNavScrollState,
    }, { immediate: true });

    requestAnimationFrame(() => {
      cacheHiddenRegionBounds();
      scheduleScrollFrame();
    });

    // Recalculate heroScrollEnd on resize (innerHeight changes on mobile browser chrome show/hide)
    window.addEventListener('resize', debounce(() => {
      cachedHeroScrollEnd = heroWrapper
        ? Math.max(0, heroWrapper.offsetHeight - window.innerHeight)
        : 0;
      cacheHiddenRegionBounds();
      scheduleScrollFrame();
    }), { passive: true });

    window.addEventListener('load', () => {
      cacheHiddenRegionBounds();
      scheduleScrollFrame();
    }, { once: true });
  }


  /* ─── Overlay open / close ───────────────────────────────────────────────── */
  const menuNavLinks = Array.from(
    overlay?.querySelectorAll<HTMLElement>('.menu-nav-link') ?? []
  );

  if (!prefersReduced) {
    menuNavLinks.forEach(link => {
      link.style.opacity   = '0';
      link.style.transform = 'translateY(10px)';
      link.style.transition = 'opacity 450ms ease, transform 450ms ease';
    });
  }

  function openMenu(): void {
    if (!overlay || !toggleBtn) return;
    overlay.dataset.open = 'true';
    overlay.setAttribute('aria-hidden', 'false');
    toggleBtn.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
    window.dispatchEvent(new Event('leo:lenis-stop'));
    if (!prefersReduced) {
      menuNavLinks.forEach((link, i) => {
        link.style.transitionDelay = `${120 + i * 55}ms`;
        link.style.opacity   = '1';
        link.style.transform = 'translateY(0)';
      });
    }
    closeBtn?.focus();
  }

  function closeMenu(): void {
    if (!overlay || !toggleBtn) return;
    if (!prefersReduced) {
      menuNavLinks.forEach(link => {
        link.style.transitionDelay = '0ms';
        link.style.opacity   = '0';
        link.style.transform = 'translateY(10px)';
      });
    }
    overlay.dataset.open = 'false';
    overlay.setAttribute('aria-hidden', 'true');
    toggleBtn.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    window.dispatchEvent(new Event('leo:lenis-start'));
    toggleBtn.focus();
  }

  toggleBtn?.addEventListener('click', () =>
    overlay?.dataset.open === 'true' ? closeMenu() : openMenu()
  );
  closeBtn?.addEventListener('click', closeMenu);

  overlay?.querySelectorAll('a').forEach(link =>
    link.addEventListener('click', closeMenu)
  );

  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape' && overlay?.dataset.open === 'true') closeMenu();
  });
</script>
