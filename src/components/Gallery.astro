---
/**
 * Gallery.astro — Sticky Grid Scroll
 *
 * Faithful Codrops-style Sticky Grid Scroll implementation using
 * GSAP + ScrollTrigger + Lenis.
 *
 * Brand tokens remain unchanged:
 * font-display, font-body, text-text-base, text-text-muted, text-accent,
 * bg-background.
 */

import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import {
  GALLERY_IMAGE_DENSITIES,
  GALLERY_IMAGE_FORMAT,
  GALLERY_IMAGE_HEIGHT,
  GALLERY_IMAGE_QUALITY,
  GALLERY_IMAGE_SIZES,
  GALLERY_IMAGE_WIDTH,
} from '../utils/galleryImages';

import left1 from '../assets/images/gallery/g61.jpg';
import left2 from '../assets/images/gallery/g8.jpg';
import left3 from '../assets/images/gallery/g65.jpg';
import left4 from '../assets/images/gallery/g3.jpg';

import mid1 from '../assets/images/gallery/g28.jpg';
import mid2 from '../assets/images/gallery/g40.jpg';
import mid3 from '../assets/images/gallery/g7.jpg';
import mid4 from '../assets/images/gallery/g8.jpg';

import right1 from '../assets/images/gallery/g38.jpg';
import right2 from '../assets/images/gallery/g52.jpg';
import right3 from '../assets/images/gallery/g15.jpg';
import right4 from '../assets/images/gallery/g59.jpg';

type GalleryImage = {
  src: ImageMetadata;
  alt: string;
  position?: string;
};

const gridImages: GalleryImage[] = [
  { src: left1, alt: 'Team member pruning a sculpted olive-tree dome against a brilliant blue sky', position: '50% 50%' },
  { src: mid1, alt: 'Aged French urns with clipped topiary beside a stone-slab-and-pebble path', position: '50% 50%' },
  { src: right1, alt: 'Romantic courtyard — wrought-iron bench, ferns in aged pots, stone chequerboard paving', position: '50% 50%' },
  { src: left2, alt: 'View through a classical arch onto a topiary garden', position: '50% 50%' },
  { src: mid2, alt: 'Team member tending a sculpted topiary ball in a French urn, pool behind', position: '50% 50%' },
  { src: right2, alt: 'Wisteria climbing a rendered period home beside clipped box hedging', position: '50% 50%' },
  { src: left3, alt: 'Lush vertical garden path — potted topiary, fig tree, stone pavers', position: '50% 100%' },
  { src: mid3, alt: 'Two crew members working a courtyard — pruning a Japanese maple and planting', position: '50% 50%' },
  { src: right3, alt: 'Team member trimming a formal hedge by a classical column', position: '50% 50%' },
  { src: left4, alt: 'Formal green garden detail with mature planting and crisp seasonal care', position: '50% 50%' },
  { src: mid4, alt: 'Established garden path bordered by sculpted greenery and layered planting', position: '50% 50%' },
  { src: right4, alt: 'Quiet heritage garden moment with lush foliage and considered maintenance', position: '50% 50%' },
];
---

<section
  id="gallery"
  data-nav-hidden-region
  data-gallery-ready="false"
  data-gallery-grid-visible="false"
  class="gallery-main block--main relative bg-background"
  aria-labelledby="gallery-heading"
>
  <div class="gallery-wrapper block__wrapper sticky top-0 px-6">
    <div class="gallery-content content relative z-10 flex h-screen w-full flex-col items-center justify-center text-center">
      <h2
        id="gallery-heading"
        class="gallery-title content__title mx-auto font-display font-normal leading-[1.15] tracking-[-0.02em] text-text-base"
      >
        <span class="text-primary-400">Gardens</span> we have<br /> the joy of tending
      </h2>

      <p class="gallery-description content__description mt-6 max-w-[28rem] font-display italic font-light text-[1.38rem] leading-[1.5] tracking-[0.004em] text-text-muted">
        A glimpse of the established Melbourne gardens in our care
      </p>

      <a
        href="https://www.instagram.com/leos_beautiful_gardens/"
        target="_blank"
        rel="noopener noreferrer"
        class="gallery-button content__button group relative mt-8 inline-flex items-center font-body text-[0.78rem] font-semibold tracking-[0.08em] text-accent transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
        aria-label="See more of our work on Instagram (opens in new tab)"
      >
        See more on Instagram
        <span class="absolute left-full ml-4 h-px w-10 origin-left scale-x-0 bg-current transition-transform duration-300 group-hover:scale-x-100" aria-hidden="true"></span>
      </a>
    </div>

    <div class="gallery-clip absolute inset-0 z-20 overflow-hidden">
      <div class="gallery absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2">
        <ul class="gallery__grid" data-gallery-grid>
          {gridImages.map((img) => (
            <li class="gallery__item overflow-hidden bg-stone-100">
              <Image
                src={img.src}
                alt={img.alt}
                width={GALLERY_IMAGE_WIDTH}
                height={GALLERY_IMAGE_HEIGHT}
                quality={GALLERY_IMAGE_QUALITY}
                format={GALLERY_IMAGE_FORMAT}
                densities={GALLERY_IMAGE_DENSITIES}
                class="gallery__image"
                style={`object-position: ${img.position ?? '50% 50%'}`}
                loading="eager"
                decoding="async"
                sizes={GALLERY_IMAGE_SIZES}
              />
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  #gallery {
    --gallery-rem: calc(100vw / 1440);
    height: 560vh;
  }

  .block__wrapper {
    transition:
      opacity 180ms ease,
      visibility 0s linear 180ms;
  }

  #gallery[data-gallery-ready="false"] .block__wrapper {
    opacity: 0;
    visibility: hidden;
  }

  #gallery[data-gallery-ready="true"] .block__wrapper {
    opacity: 1;
    visibility: visible;
    transition: opacity 180ms ease;
  }

  .content__title {
    width: min(calc(924 * var(--gallery-rem)), 100%);
    font-size: clamp(2.5rem, calc(104 * var(--gallery-rem)), 6.5rem);
  }

  .gallery {
    width: min(calc(736 * var(--gallery-rem)), 90vw);
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 260ms ease,
      visibility 0s linear 260ms;
  }

  #gallery[data-gallery-grid-visible="true"] .gallery {
    opacity: 1;
    visibility: visible;
    transition: opacity 260ms ease;
  }

  .gallery__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    column-gap: clamp(0.75rem, calc(32 * var(--gallery-rem)), 2rem);
    row-gap: clamp(1rem, calc(40 * var(--gallery-rem)), 2.5rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .gallery__item {
    width: 100%;
    aspect-ratio: 1;
  }

  .gallery__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>

<script>
  import { gsap, ScrollTrigger } from '../utils/gsap';

  type GalleryWindow = Window & {
    __leoGalleryGsapInitialized?: boolean;
  };

  const galleryWindow = window as GalleryWindow;
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  class StickyGridScroll {
    block: HTMLElement | null = null;
    wrapper: HTMLElement | null = null;
    content: HTMLElement | null = null;
    title: HTMLElement | null = null;
    description: HTMLElement | null = null;
    button: HTMLElement | null = null;
    grid: HTMLElement | null = null;
    items: NodeListOf<HTMLElement> = document.querySelectorAll<HTMLElement>('.gallery__item');
    numColumns = 3;
    columns: HTMLElement[][] = [];
    titleOffsetY = 0;
    revealDy = 0;
    contentTimeline: gsap.core.Timeline | null = null;

    constructor() {
      this.getElements();

      if (!this.block || !this.wrapper || !this.content || !this.title || !this.description || !this.button || !this.grid || this.items.length === 0) {
        return;
      }

      this.initContent();
      this.groupItemsByColumn();
      this.observeWillChange();
      this.animateTitleOnScroll();
      const wh = window.innerHeight;
      this.revealDy = wh - (wh - this.grid!.offsetHeight) / 2;
      this.animateGridOnScroll();
    }

    getElements(): void {
      this.block = document.querySelector<HTMLElement>('.block--main');

      if (!this.block) {
        return;
      }

      this.wrapper = this.block.querySelector<HTMLElement>('.block__wrapper');
      this.content = this.block.querySelector<HTMLElement>('.content');
      this.title = this.block.querySelector<HTMLElement>('.content__title');
      this.description = this.block.querySelector<HTMLElement>('.content__description');
      this.button = this.block.querySelector<HTMLElement>('.content__button');
      this.grid = this.block.querySelector<HTMLElement>('.gallery__grid');
      this.items = this.block.querySelectorAll<HTMLElement>('.gallery__item');
    }

    initContent(): void {
      gsap.set([this.description, this.button], { opacity: 0, pointerEvents: 'none' });
      gsap.set(this.grid, { force3D: true, transformOrigin: '50% 50%' });

      const dy = (this.content!.offsetHeight - this.title!.offsetHeight) / 2;
      this.titleOffsetY = (dy / this.content!.offsetHeight) * 100;
      gsap.set(this.title, { yPercent: this.titleOffsetY });
      this.createContentTimeline();
    }

    createContentTimeline(): void {
      this.contentTimeline = gsap.timeline({
        paused: true,
        defaults: { overwrite: 'auto' },
      })
        .to(this.title, {
          yPercent: 0,
          duration: 0.7,
          ease: 'power2.inOut',
        })
        .to(
          [this.description, this.button],
          {
            opacity: 1,
            duration: 0.4,
            ease: 'power1.inOut',
            pointerEvents: 'all',
          },
          '-=90%',
        );
    }

    observeWillChange(): void {
      if (!this.block || !this.grid) return;

      const observer = new IntersectionObserver(
        (entries) => {
          if (!this.grid) return;
          this.grid.style.willChange = entries[0].isIntersecting ? 'transform' : 'auto';
        },
        { rootMargin: '300px 0px 300px 0px' },
      );

      observer.observe(this.block);
    }

    groupItemsByColumn(): void {
      this.columns = Array.from({ length: this.numColumns }, () => []);
      this.items.forEach((item, index) => {
        this.columns[index % this.numColumns].push(item);
      });
    }

    animateTitleOnScroll(): void {
      gsap.from(this.title, {
        opacity: 0,
        duration: 0.7,
        ease: 'power1.out',
        scrollTrigger: {
          trigger: this.block,
          start: 'top 57%',
          toggleActions: 'play none none reset',
        },
      });
    }

    gridRevealTimeline(columns = this.columns): gsap.core.Timeline {
      const timeline = gsap.timeline();
      const dy = this.revealDy;

      columns.forEach((column, colIndex) => {
        const fromTop = colIndex % 2 === 0;

        timeline.from(
          column,
          {
            y: dy * (fromTop ? -1 : 1),
            duration: 0.5,
            stagger: {
              each: 0.06,
              from: fromTop ? 'end' : 'start',
            },
            ease: 'power1.inOut',
          },
          'grid-reveal',
        );
      });

      return timeline;
    }

    gridZoomTimeline(columns = this.columns): gsap.core.Timeline {
      const timeline = gsap.timeline({ defaults: { duration: 1, ease: 'power3.inOut', force3D: true } });

      timeline.to(this.grid, { scale: 2.05, force3D: true });
      timeline.to(columns[0], { xPercent: -40 }, '<');
      timeline.to(columns[2], { xPercent: 40 }, '<');
      timeline.to(
        columns[1],
        {
          yPercent: (index) => (index < Math.floor(columns[1].length / 2) ? -1 : 1) * 40,
          duration: 0.5,
          ease: 'power1.inOut',
        },
        '-=0.5',
      );

      return timeline;
    }

    animateGridOnScroll(): void {
      const timeline = gsap.timeline({
        scrollTrigger: {
          trigger: this.block,
          start: 'top 25%',
          end: 'bottom bottom',
          scrub: true,
          // Forward: grid appears, content toggles on at the end
          onEnter: () => {
            if (this.block) this.block.dataset.galleryGridVisible = 'true';
          },
          // Scrolled past the bottom of the section
          onLeave: () => {
            if (this.block) this.block.dataset.galleryGridVisible = 'false';
          },
          // Scrolled back down into section from below
          onEnterBack: () => {
            if (this.block) this.block.dataset.galleryGridVisible = 'true';
          },
          // Scrolled back up above the section — reset everything cleanly
          onLeaveBack: () => {
            if (this.block) this.block.dataset.galleryGridVisible = 'false';
            // Snap content back to its pre-animation state so it's
            // ready for the next forward pass without a flash
            this.contentTimeline?.pause(0);
            gsap.set([this.description, this.button], { opacity: 0, pointerEvents: 'none' });
          },
        },
      });

      // Use ScrollTrigger direction at call-time so scrub callbacks can
      // play/reverse the prebuilt content timeline without allocating.
      const self = this;
      timeline
        .add(this.gridRevealTimeline())
        .add(this.gridZoomTimeline(), '-=0.6')
        // Use timeline.progress() at call-time instead of scrollTrigger.direction,
        // which can be stale when the callback fires during scrub playback.
        .add(function() {
          const goingForward = (timeline.scrollTrigger?.direction ?? 1) === 1;
          if (goingForward) {
            self.contentTimeline?.play();
          } else {
            self.contentTimeline?.reverse();
          }
        }, '-=0.32');
    }

  }

  function revealReducedMotionContent(): void {
    const gallerySection = document.querySelector<HTMLElement>('#gallery');
    const description = document.querySelector<HTMLElement>('.gallery-description');
    const button = document.querySelector<HTMLElement>('.gallery-button');
    if (gallerySection) gallerySection.dataset.galleryReady = 'true';
    gsap.set([description, button], { opacity: 1, pointerEvents: 'auto' });
  }

  let galleryImagesDecoded = false;

  async function decodeGalleryImages(): Promise<void> {
    const images = Array.from(
      document.querySelectorAll<HTMLImageElement>('.gallery__image')
    );

    await Promise.all(
      images.map((img) => img.decode().catch(() => Promise.resolve()))
    );

    galleryImagesDecoded = true;
    const gallerySection = document.querySelector<HTMLElement>('#gallery');
    if (gallerySection) gallerySection.dataset.galleryReady = 'true';
  }

  function initStickyGridScroll(): void {
    if (!galleryImagesDecoded) return;

    requestAnimationFrame(() => {
      new StickyGridScroll();
      ScrollTrigger.refresh();
    });
  }

  function observeGalleryForDecode(): void {
    const gallerySection = document.querySelector<HTMLElement>('#gallery');

    if (!gallerySection || !('IntersectionObserver' in window)) {
      decodeGalleryImages().then(initStickyGridScroll);
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        if (!entries.some((entry) => entry.isIntersecting)) return;

        observer.disconnect();
        decodeGalleryImages().then(initStickyGridScroll);
      },
      { rootMargin: '200% 0px' },
    );

    observer.observe(gallerySection);
  }

  if (prefersReduced) {
    revealReducedMotionContent();
  } else if (!galleryWindow.__leoGalleryGsapInitialized) {
    galleryWindow.__leoGalleryGsapInitialized = true;
    observeGalleryForDecode();
  }
</script>
