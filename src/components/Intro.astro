---
import { Image } from 'astro:assets';
import img19 from '../assets/images/img_19.jpg';
---

<!-- Intro / Value Proposition — asymmetric 2-col split -->
<section
  id="intro"
  class="py-20 md:py-section bg-background"
  aria-labelledby="intro-heading"
>
  <div class="max-w-container mx-auto px-6 md:px-10">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-14 items-center">

      <!-- Text column -->
      <div class="md:col-span-6 space-y-5 intro-reveal">
        <p class="font-body text-label text-text-muted tracking-widest uppercase">
          Who we are
        </p>
        <h2
          id="intro-heading"
          class="font-display text-heading-xl text-text-base"
        >
          Specialists in the gardens that deserve it.
        </h2>
        <p class="font-body text-body-lg text-text-muted leading-relaxed">
          Leo's Beautiful Gardens looks after established, design-led gardens across
          Melbourne — the box hedges, sculpted topiary, heritage courtyards and mature
          trees that need a skilled, trusted hand.
        </p>
        <p class="font-body text-body-md text-text-muted leading-relaxed">
          We're a small, fully-equipped team who treat every plant as a living thing
          worth caring for, and every client's garden as if it were our own. Whether you
          need dependable fortnightly maintenance or a full seasonal renewal, we keep
          your garden looking its considered best — all year.
        </p>
        <div class="pt-2">
          <a
            href="#contact"
            class="inline-flex items-center gap-2 font-body font-semibold text-body-md text-accent hover:text-accent-600 transition-colors duration-200 motion-reduce:transition-none cursor-pointer group"
          >
            Get a free quote
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round"
                 aria-hidden="true"
                 class="transition-transform duration-200 group-hover:translate-x-1 motion-reduce:transition-none">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Image column -->
      <div class="md:col-span-6 intro-reveal" style="transition-delay: 150ms">
        <div class="rounded-brand-lg overflow-hidden shadow-brand-lg aspect-[4/5] md:aspect-[5/6]">
          <Image
            src={img19}
            alt="Leo's team member carefully tending a sculpted topiary ball in a formal French urn, with a lush lawn and pool visible behind"
            width={800}
            height={960}
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  // Scroll-reveal — fade up 16px, once
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const items = document.querySelectorAll<HTMLElement>('.intro-reveal');

  if (!prefersReduced) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            el.style.transition = `opacity 600ms ease-out ${el.style.transitionDelay || '0ms'}, transform 600ms ease-out ${el.style.transitionDelay || '0ms'}`;
            el.style.opacity   = '1';
            el.style.transform = 'translateY(0)';
            io.unobserve(el);
          }
        });
      },
      { threshold: 0.15 }
    );

    items.forEach(el => {
      el.style.opacity   = '0';
      el.style.transform = 'translateY(16px)';
      io.observe(el);
    });
  }
</script>
