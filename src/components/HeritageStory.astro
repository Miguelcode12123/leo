---
/**
 * HeritageStory.astro — Leo's Beautiful Gardens
 *
 * Four-zone heritage section. Aesthetic: Heckfield Place / Aesop —
 * editorial stillness, cream ground, one terracotta accent.
 *
 * Zone 1 — Declaration:    2-col grid, typographic sculpture + tilted portrait
 * Zone 3 — Sticky scene:   lead paragraph + cinematic card rise (merged zones 2+3)
 * Zone 4 — Closing:        second paragraph, signature, read-link
 *
 * ── Why the text lives inside the sticky scene ──────────────────────────────
 *
 *  The "card rises over text" effect requires both elements to share the same
 *  scroll reference frame. If the text is in normal document flow (as it was),
 *  it moves upward at 1px per scroll-px. The card in a sticky container also
 *  moves upward, but only at (startY / scrollBudget) px per scroll-px. At
 *  typical desktop heights these rates are nearly identical — the card can
 *  never catch the text.
 *
 *  Putting the text INSIDE the sticky container freezes it in place while the
 *  card rises beneath it. The relative motion is now the full card travel
 *  (= 100vh) rather than the near-zero differential. The overlap moment is
 *  guaranteed and predictable across all screen sizes.
 *
 * ── Desktop geometry ────────────────────────────────────────────────────────
 *
 *   Stage height    = 200vh  (= 100vh viewport + 100vh scroll budget)
 *   Scroll budget   = 100vh
 *   Card startY     = 36.7vh (matches the upper and lower visual gaps)
 *   Card velocity   = 1px per scroll-px  (1:1 with user scroll)
 *
 *   Text is absolutely positioned at top:35% of the sticky frame ≈ 315px.
 *   Card natural top ≈ 141px, natural bottom ≈ 759px (at 1440×900).
 *   Card begins covering text at progress ≈ 56% (card top < text bottom).
 *   Text fully behind card at progress ≈ 81%.
 *
 * ── Portrait parallax (img_17) ──────────────────────────────────────────────
 *   factor 0.30 → ~180 px travel at 600 px centre-offset
 *   rotation –2.2° → 0° as element crosses viewport centre
 */

import { Image } from 'astro:assets';
import img17 from '../assets/images/img_17.jpg';
import img23 from '../assets/images/img_23.jpg';
---

<section
  id="heritage"
  aria-labelledby="heritage-heading"
>
  <div class="h-canvas" id="h-canvas">
    <div class="h-container">

      <!-- ─────────────────────────────────────────────────────────────────────
           ZONE 1 · DECLARATION
           2-col grid: typographic sculpture (left) · img_17 portrait (right).
           Framer Motion drives translateY + rotation on the portrait via
           inline style on #h-decl-img.
      ───────────────────────────────────────────────────────────────────────── -->
      <div class="h-decl h-zone" id="h-decl">

        <div class="h-decl-type">
          <p class="h-eyebrow">Heritage</p>
          <h2 id="heritage-heading" class="h-title">
            <span class="h-title-four">Four</span>
            <span class="h-title-gen">generations</span>
            <span class="h-title-craft">of <em>craft.</em></span>
          </h2>
        </div>

        <div class="h-decl-img" id="h-decl-img">
          <Image
            src={img17}
            alt="A gardener on a tall ladder shaping a mature olive tree against a clear blue sky."
            width={840}
            height={1120}
            quality={90}
            densities={[1, 2]}
            class="h-portrait"
            loading="lazy"
          />
        </div>

      </div><!-- /h-decl -->


      <!-- ─────────────────────────────────────────────────────────────────────
           ZONE 3 · STICKY SCENE  (contains what was Zone 2 + the card)
           
           On desktop: position:sticky pins this for 100vh of scroll.
           The lead paragraph is frozen in the upper-middle of the frame.
           The card rises from below and covers it.
           
           On mobile: everything renders in normal flow (static, no animation).
      ───────────────────────────────────────────────────────────────────────── -->
      <div class="h-pivot-scroll-stage">
        <div class="h-pivot-sticky">

          <!-- Lead paragraph — frozen in sticky frame on desktop,
               normal flow on mobile. Card rises over this. -->
          <div class="h-pivot-text-layer">
            <hr class="h-hairline" aria-hidden="true" />
            <p class="letter lead">
              Leonardo grew up among the olive groves of southern Sicily, where his
              grandfather Rosario taught him <em>to tend a garden the way a family
              tends a name</em> — with patience, with specificity, and with a long
              view of what you are actually building.
            </p>
          </div>

          <!-- Card image — starts below viewport, rises to cover the text -->
          <div class="h-pivot-card">
            <Image
              src={img23}
              alt="Leonardo Qucco standing on a stone path beneath a tunnel of autumn vines."
              width={2400}
              height={1350}
              quality={90}
              densities={[1, 2]}
              class="h-pivot-img"
              loading="lazy"
            />
          </div>

        </div>
      </div><!-- /h-pivot-scroll-stage -->


      <!-- ─────────────────────────────────────────────────────────────────────
           ZONE 4 · CLOSING
           Second paragraph, signature, read-link. No dropcap.
           nth-child(3) in .h-container (Zone 1 = 1, stage = 2, this = 3).
      ───────────────────────────────────────────────────────────────────────── -->
      <div class="h-chrome h-zone h-closing">
        <div class="h-prose-col">

          <p class="letter">
            Today the same craft is practised here in Melbourne, by the same
            small team, on the day we said we would.
          </p>

          <div class="h-sig">
            <p class="h-sig-name">Leonardo Qucco</p>
            <span class="h-sig-meta">Founder</span>
          </div>

          <a href="#our-story" class="h-read-link" aria-label="Read our story">
            <span class="h-read-label">Read our story</span>
            <span class="h-read-rule" aria-hidden="true"></span>
          </a>

        </div>
      </div>

    </div><!-- /.h-container -->
  </div><!-- /#h-canvas -->
</section>


<style>
  /* ═══════════════════════════════════════════════════════════════════════════
     Design tokens
  ═══════════════════════════════════════════════════════════════════════════ */
  #heritage {
    --cream:      #F7F4EC;
    --ink:        #1F2A1A;
    --muted:      #5E6B54;
    --green-700:  #2E4628;
    --terra-500:  #B45F38;
    --ink-soft:   rgba(31, 42, 26, 0.42);
  }

  /* ═══════════════════════════════════════════════════════════════════════════
     Section shell
  ═══════════════════════════════════════════════════════════════════════════ */
  #heritage {
    background-color: var(--cream);
    padding-top:    clamp(18rem, 38vh, 26rem);
    padding-bottom: clamp(9rem, 18vh, 14rem);
  }

  /* ═══════════════════════════════════════════════════════════════════════════
     Container
  ═══════════════════════════════════════════════════════════════════════════ */
  .h-container {
    max-width: 84rem;
    margin-inline: auto;
    padding-inline: 1.5rem;
  }
  @media (min-width: 768px)  { .h-container { padding-inline: 2.5rem; } }
  @media (min-width: 1280px) { .h-container { padding-inline: 4rem; } }

  /* ═══════════════════════════════════════════════════════════════════════════
     ZONE 1 — Declaration grid
  ═══════════════════════════════════════════════════════════════════════════ */
  .h-decl {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
    margin-bottom: 0;
  }
  @media (min-width: 1024px) {
    .h-decl {
      grid-template-columns: 1fr clamp(360px, 40vw, 500px);
      gap: 4rem 4rem;
    }
  }

  .h-eyebrow {
    font-family: 'Mulish', sans-serif;
    font-weight: 500;
    font-size: 0.72rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 1.5rem;
  }

  .h-title {
    font-family: 'Fraunces', serif;
    font-optical-sizing: auto;
    line-height: 0.96;
    letter-spacing: -0.028em;
    color: var(--ink);
    font-style: normal;
  }
  .h-title-four {
    display: block;
    font-weight: 400;
    font-size: clamp(4.5rem, 9.5vw, 8.5rem);
  }
  .h-title-gen {
    display: block;
    font-weight: 300;
    font-style: italic;
    font-size: clamp(2.4rem, 4.5vw, 4rem);
    color: var(--ink-soft);
    padding-left: 0.5ch;
    margin: 0.15rem 0 0.2rem;
  }
  .h-title-craft {
    display: block;
    font-weight: 400;
    font-size: clamp(3.6rem, 7.2vw, 6.5rem);
  }
  .h-title em {
    font-style: normal;
    color: var(--green-700);
  }

  .h-decl-img {
    max-width: 24rem;
    margin: 0 auto;
  }
  @media (min-width: 1024px) {
    .h-decl-img {
      max-width: none;
      margin: 0;
      will-change: transform;
    }
  }
  .h-portrait {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    object-position: 50% 42%;
    display: block;
  }

  /* ═══════════════════════════════════════════════════════════════════════════
     ZONE 3 — Sticky scene
     ── Mobile (default): static, no animation ──────────────────────────────
  ═══════════════════════════════════════════════════════════════════════════ */
  .h-pivot-scroll-stage { position: relative; }

  /* Mobile text layer: replicates the old h-chrome Zone 2 appearance */
  .h-pivot-text-layer {
    max-width: 34rem;
    margin-inline: auto;
    text-align: center;
    padding-block: 0 2rem;
  }

  .h-pivot-card { width: 100%; }

  .h-pivot-img {
    aspect-ratio: 5 / 3;
    object-fit: cover;
    object-position: 50% 32%;
    width: 100%;
    display: block;
  }

  /* ── Desktop: scroll-jacked sticky ─────────────────────────────────────────
   *
   *  GEOMETRY:
   *
   *    Stage height  = 200vh  →  scroll budget = 100vh
   *    No negative margin: stage is placed normally after Zone 1. Sticky
   *    activates when Zone 1 scrolls off the top.
   *
   *    Text layer is absolutely positioned at top:35% of the sticky frame
   *    (≈ 315px at 900px viewport). This sits squarely within the card's
   *    natural bounding box (card top ≈ 141px, card bottom ≈ 759px), so the
   *    card will fully cover the text by the time it reaches its rest position.
   *
   *    Card travel = 36.7vh. Card starts close beneath the paragraph so the
   *    first image edge arrives sooner.
   *    Since the text is stationary (inside the sticky frame), relative
   *    velocity = full card travel = 100vh. The card closes the gap.
   *
   *    Overlap timeline at 1440×900:
   *      progress 0%  → card off-screen below, text fully visible
   *      progress 56% → card bottom reaches text bottom, covering begins
   *      progress 81% → text fully behind card
   *      progress 100%→ card at rest, sticky releases
   *
   *  z-index: card (2) is above text (1), both inside sticky (z-index 20).
  ═══════════════════════════════════════════════════════════════════════════ */
  @media (min-width: 1024px) {

    .h-pivot-scroll-stage {
      height: 200vh;
      margin-top: clamp(-4rem, -6vh, -2rem);
      position: relative;
      z-index: 20;
    }

    .h-pivot-sticky {
      position: sticky;
      top: 0;
      width: 100%;
      height: 100vh;
      overflow: hidden;
      /*
       * Flexbox centres the card horizontally and vertically at translateY(0).
       * The text layer is absolutely positioned on top of this layout.
       */
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /*
     * Text layer: frozen in the upper part of the sticky frame.
     * top:13% places it at ≈ 117px from viewport top — still within the card's
     * bounding box, ensuring the card covers it as it reaches rest.
     *
     * z-index:1 keeps it behind the rising card (z-index:2).
     * pointer-events:none prevents accidental selection under the card.
     */
    .h-pivot-text-layer {
      position: absolute;
      top: 13%;
      left: 50%;
      transform: translateX(-50%);
      width: min(30rem, 90%);
      padding: 0;
      text-align: center;
      z-index: 1;
      pointer-events: none;
    }

    /*
     * Card: flexbox centres it (translateY:0 = natural rest position).
     * JS sets the initial translateY(+startY) and animates it to translateY(0).
     * z-index:2 ensures card appears above the text layer.
     */
    .h-pivot-card {
      position: relative;
      width: min(90%, 1100px);
      z-index: 2;
      will-change: transform;
      flex-shrink: 0;
    }

    .h-pivot-img { aspect-ratio: 16 / 9; }
  }

  /* ═══════════════════════════════════════════════════════════════════════════
     SHARED prose / hairline — used in both the sticky text layer and Zone 4
  ═══════════════════════════════════════════════════════════════════════════ */
  .h-hairline {
    display: block;
    width: 3.5rem;
    height: 1px;
    background: var(--green-700);
    opacity: 0.45;
    margin: 0 auto 3.5rem;
    border: 0;
  }

  .letter {
    font-family: 'Fraunces', serif;
    font-optical-sizing: auto;
    font-weight: 300;
    font-size: 1.15rem;
    line-height: 1.75;
    letter-spacing: 0.005em;
    color: var(--ink);
    text-align: left;
    max-width: 30rem;
    text-wrap: pretty;
    margin: 0 auto;
  }
  @media (min-width: 1024px) {
    .letter {
      font-weight: 400;
      font-size: 1.2rem;
      line-height: 1.78;
    }
  }

  /*
   * flow-root contains the floated drop-cap within the paragraph, preventing
   * surrounding layout from wrapping or shifting around the float.
   */
  .letter.lead { display: flow-root; }

  .letter.lead::first-letter {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 4em;
    float: left;
    line-height: 0.82;
    margin: 0.3rem 0.55rem -0.1rem 0;
    color: var(--terra-500);
  }

  /* ═══════════════════════════════════════════════════════════════════════════
     ZONE 4 — Closing chrome
  ═══════════════════════════════════════════════════════════════════════════ */
  .h-chrome {
    max-width: 34rem;
    margin-inline: auto;
    text-align: center;
  }
  @media (min-width: 1024px) {
    .h-closing {
      margin-top: -0.9rem;
    }
  }

  .h-sig {
    margin-top: 2.75rem;
  }
  .h-sig-name {
    font-family: 'Fraunces', serif;
    font-optical-sizing: auto;
    font-style: italic;
    font-weight: 400;
    font-size: 1.15rem;
    line-height: 1.45;
    color: var(--ink);
    margin: 0;
  }
  .h-sig-meta {
    font-family: 'Mulish', sans-serif;
    font-weight: 500;
    font-size: 0.68rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--muted);
    display: block;
    margin-top: 0.65rem;
  }

  .h-read-link {
    display: inline-flex;
    align-items: center;
    gap: 1.15rem;
    margin-top: 3.5rem;
    text-decoration: none;
    color: var(--ink);
    font-family: 'Mulish', sans-serif;
    font-weight: 500;
    font-size: 0.74rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    transition: color 0.3s ease;
  }
  .h-read-link:hover { color: var(--green-700); }
  .h-read-link:focus-visible {
    outline: 2px solid var(--terra-500);
    outline-offset: 4px;
    border-radius: 1px;
  }
  .h-read-rule {
    display: block;
    width: 2.75rem;
    height: 1px;
    background: currentColor;
    opacity: 0.5;
    flex-shrink: 0;
    transition:
      width   0.7s cubic-bezier(0.2, 0.7, 0.2, 1),
      opacity 0.7s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .h-read-link:hover .h-read-rule,
  .h-read-link:focus-visible .h-read-rule {
    width: 4.25rem;
    opacity: 0.9;
  }

  /* ═══════════════════════════════════════════════════════════════════════════
     Reveal animation
     .h-container children:
       1 → .h-decl.h-zone          delay   0ms
       2 → .h-pivot-scroll-stage   (not h-zone)
       3 → .h-chrome.h-zone        delay 260ms
  ═══════════════════════════════════════════════════════════════════════════ */
  .h-zone {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity   1.1s cubic-bezier(0.2, 0.7, 0.2, 1),
      transform 1.1s cubic-bezier(0.2, 0.7, 0.2, 1);
  }

  .h-zone:nth-child(1) { transition-delay:   0ms; }
  .h-zone:nth-child(3) { transition-delay: 260ms; }

  .h-canvas.h-revealed .h-zone {
    opacity: 1;
    transform: none;
  }

  /* ═══════════════════════════════════════════════════════════════════════════
     Reduced motion
  ═══════════════════════════════════════════════════════════════════════════ */
  @media (prefers-reduced-motion: reduce) {
    .h-zone { opacity: 1; transform: none; transition: none; }
    .h-read-rule { transition: none; }
  }
</style>


<script>
  import { gsap } from 'gsap';

  /**
   * Heritage section — animation driver
   *
   * ── 1. Reveal on enter ───────────────────────────────────────────────────
   *    IntersectionObserver on #h-canvas → adds .h-revealed.
   *    Zone 1 and Zone 4 (.h-zone) fade + lift in.
   *
   * ── 2. Scroll driver (desktop ≥ 1024px only) ─────────────────────────────
   *
   *    A) Portrait parallax (img_17)
   *       centre-offset formula:
   *         center = elementMidY − viewportMidY
   *         y      = center × 0.30
   *       Rotation: –2.2° when element is below viewport centre, 0° at centre.
   *
   *    B) Card scroll-jack (img_23)
   *
   *       The lead paragraph is inside .h-pivot-sticky (frozen in place).
   *       The card is also inside .h-pivot-sticky (centred via flexbox).
   *
   *       Stage height = 200vh → scroll budget = 100vh.
   *       startY = 36.7vh (matches the upper and lower visual gaps).
   *
   *       progress = clamp(0, –stage.top / scrollBudget, 1)
   *       y        = startY × (1 − progress)
   *
   *       At progress 0:   card at translateY(+vh) — off-screen below.
   *       At progress 1:   card at translateY(0)   — resting at centre.
   *
   *       The text layer is stationary (absolute inside sticky), so the card
   *       closes the full ~vh gap as it rises. Text is covered by progress ≈ 80%.
   */

  const canvas  = document.getElementById('h-canvas')   as HTMLElement | null;
  const declImg = document.getElementById('h-decl-img') as HTMLElement | null;

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isDesktop      = window.matchMedia('(min-width: 1024px)').matches;

  /* ── 1. Reveal ──────────────────────────────────────────────────────────── */
  if (prefersReduced) {
    canvas?.classList.add('h-revealed');
  } else if (canvas) {
    const revealObs = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          canvas.classList.add('h-revealed');
          revealObs.disconnect();
        }
      },
      { rootMargin: '0px 0px -10% 0px', threshold: 0.05 }
    );
    revealObs.observe(canvas);
  }

  /* ── 2. Scroll driver ───────────────────────────────────────────────────── */
  if (!prefersReduced && isDesktop) {

    const IMG17_FACTOR = 0.30;
    const MAX_ROT      = -2.2;

    const pivotStage = document.querySelector<HTMLElement>('.h-pivot-scroll-stage');
    const pivotCard  = document.querySelector<HTMLElement>('.h-pivot-card');
    const setPivotY = pivotCard ? gsap.quickSetter(pivotCard, 'y', 'px') : null;

    if (pivotCard) {
      gsap.set(pivotCard, {
        y: window.innerHeight * 0.367,
        force3D: true,
      });
    }

    let rafId = 0;

    const tick = () => {
      const vh = window.innerHeight;

      /* A) img_17 — portrait parallax + tilt */
      if (declImg) {
        const r      = declImg.getBoundingClientRect();
        const center = r.top + r.height / 2 - vh / 2;
        const y      = center * IMG17_FACTOR;
        const rotT   = Math.max(0, Math.min(1, center / vh));
        const rot    = MAX_ROT * rotT;
        declImg.style.transform =
          `translateY(${y.toFixed(1)}px) rotate(${rot.toFixed(3)}deg)`;
      }

      /* B) img_23 — scroll-jacked card rise
       *
       *  Both card and text are in the same sticky container, so the text
       *  stays frozen while the card rises. startY below 100vh brings the
       *  image in sooner while preserving scroll-driven motion.
       */
      if (pivotStage && pivotCard) {
        const r            = pivotStage.getBoundingClientRect();
        const scrollBudget = Math.max(1, pivotStage.offsetHeight - vh);
        const progress     = Math.max(0, Math.min(1, -r.top / scrollBudget));
        const startY       = vh * 0.367;
        const y            = startY * (1 - progress);
        if (setPivotY) {
          setPivotY(y);
        } else {
          pivotCard.style.transform = `translate3d(0, ${y.toFixed(1)}px, 0)`;
        }
      }

      rafId = 0;
    };

    const scheduleTick = () => {
      if (!rafId) rafId = requestAnimationFrame(tick);
    };

    type LenisLike = {
      on?: (event: 'scroll', callback: () => void) => (() => void) | void;
    };

    const lenisWindow = window as Window & { __leoLenis?: LenisLike };
    let usingLenisScroll = false;

    function bindLenisScroll(): boolean {
      if (usingLenisScroll || !lenisWindow.__leoLenis?.on) {
        return false;
      }

      lenisWindow.__leoLenis.on('scroll', scheduleTick);
      window.removeEventListener('scroll', scheduleTick);
      usingLenisScroll = true;
      scheduleTick();
      return true;
    }

    requestAnimationFrame(() => {
      if (!bindLenisScroll()) {
        window.addEventListener('scroll', scheduleTick, { passive: true });
      }
    });

    window.addEventListener('leo:lenis-ready', bindLenisScroll);

    /* Wait for images to decode and lay out before the first tick so that
       getBoundingClientRect() and offsetHeight are accurate. */
    if (document.readyState === 'complete') {
      requestAnimationFrame(tick);
    } else {
      window.addEventListener('load', () => requestAnimationFrame(tick), { once: true });
    }

  }
</script>
