---
import Layout        from '../layouts/Layout.astro';
import Nav           from '../components/Nav.astro';
import HeritageStory from '../components/HeritageStory.astro';
import Team          from '../components/Team.astro';
import ContactCta    from '../components/ContactCta.astro';
import Footer        from '../components/Footer.astro';
import { Image }     from 'astro:assets';
import img24         from '../assets/images/img_24.jpg';
---

<Layout
  title="About Leo's Beautiful Gardens | Melbourne Garden Care"
  description="Meet Leonardo — fourth-generation Sicilian gardener and founder of Leo's Beautiful Gardens. Our story, our team, and our philosophy of garden care as craft."
>
  <Nav transparent={false} />

  <!-- Page hero -->
  <div class="relative py-24 md:py-32 bg-primary overflow-hidden">
    <Image
      src={img24}
      alt="Bare hands firming soil around a freshly planted leafy plant — the G.R.O.W.T.H ethos of respect for life"
      width={1920}
      height={600}
      class="absolute inset-0 w-full h-full object-cover opacity-20"
      loading="eager"
    />
    <div class="relative max-w-container mx-auto px-6 md:px-10 text-center">
      <p class="font-body text-label text-secondary-400 tracking-widest uppercase mb-4">Our story</p>
      <h1 class="font-display text-display-lg text-surface max-w-2xl mx-auto">
        Rooted in Sicily. Growing in Melbourne.
      </h1>
      <p class="font-body text-body-lg text-secondary-200 max-w-xl mx-auto mt-5">
        A fourth-generation gardening family who treat every plant as a living masterpiece and every garden as their own.
      </p>
    </div>
  </div>

  <!-- G.R.O.W.T.H philosophy band -->
  <section class="py-20 md:py-section bg-background" aria-labelledby="philosophy-heading">
    <div class="max-w-container mx-auto px-6 md:px-10">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-14 items-center">

        <!-- Image: hands in soil -->
        <div class="md:col-span-5">
          <div class="rounded-brand-lg overflow-hidden shadow-brand-lg aspect-square">
            <Image
              src={img24}
              alt="Bare hands firming soil around a freshly planted plant — respect for living things"
              width={700}
              height={700}
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </div>

        <!-- Philosophy copy -->
        <div class="md:col-span-7 space-y-6">
          <p class="font-body text-label text-text-muted tracking-widest uppercase">Our philosophy</p>
          <h2 id="philosophy-heading" class="font-display text-heading-xl text-text-base">
            Gardens that grow with care.
          </h2>
          <p class="font-body text-body-lg text-text-muted leading-relaxed">
            We believe every plant is a living thing worth respecting — not simply managing. That belief drives everything from how we approach a fortnightly maintenance visit to how we design a full garden renovation.
          </p>
          <p class="font-body text-body-md text-text-muted leading-relaxed">
            Our team arrives prepared, pays attention, and leaves a garden better than we found it. We don't rush. We don't cut corners. We work the way Leonardo's grandfather Rosario taught him to: with patience, skill, and a genuine love for the living world.
          </p>

          <!-- Values list -->
          <ul class="space-y-3 pt-2 list-none m-0 p-0">
            {[
              'Genuine horticultural knowledge, not guesswork',
              'Species-aware pruning and planting decisions',
              'Eco-friendly, natural-first pest control',
              'The same trusted faces, every single visit',
              'Honest, transparent communication with every client',
            ].map(value => (
              <li class="flex items-start gap-3 font-body text-body-md text-text-muted">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                     fill="none" stroke="#B45F38" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                     aria-hidden="true" class="flex-shrink-0 mt-0.5">
                  <path d="M20 6 9 17l-5-5"/>
                </svg>
                {value}
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </section>

  <HeritageStory />
  <Team />
  <ContactCta />
  <Footer />
</Layout>
