---
import Layout     from '../layouts/Layout.astro';
import SmoothScroll from '../components/SmoothScroll.astro';
import Nav        from '../components/Nav.astro';
import ContactCta from '../components/ContactCta.astro';
import Footer     from '../components/Footer.astro';
import { Image }  from 'astro:assets';
import img18      from '../assets/images/img_18.jpg';
---

<Layout
  title="Contact Leo's Beautiful Gardens | Free Garden Quotes Melbourne"
  description="Get a free, no-obligation quote for garden maintenance, pruning, landscaping or pre-sale preparation across Melbourne. Call 0449 915 712 or send us a message."
>
  <SmoothScroll />

  <Nav transparent={false} />

  <!-- Page hero -->
  <div class="relative py-24 md:py-32 bg-primary overflow-hidden">
    <Image
      src={img18}
      alt="Leo's Beautiful Gardens branded white work ute parked at an ivy-clad heritage building — a real, trusted operation"
      width={1920}
      height={600}
      class="absolute inset-0 w-full h-full object-cover opacity-25"
      loading="eager"
    />
    <div class="relative max-w-container mx-auto px-6 md:px-10 text-center">
      <p class="font-body text-label text-secondary-400 tracking-widest uppercase mb-4">Get in touch</p>
      <h1 class="font-display text-display-lg text-surface max-w-2xl mx-auto">
        Let's talk about your garden.
      </h1>
      <p class="font-body text-body-lg text-secondary-200 max-w-xl mx-auto mt-5">
        Free quotes, no obligation. We service Armadale, Toorak, Malvern, Brighton, Hawthorn and all of Melbourne's inner south-east, plus the Mornington Peninsula.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <a
          href="tel:+61449915712"
          class="inline-flex items-center justify-center gap-2 rounded-pill bg-accent text-surface px-7 py-3.5 font-body font-semibold text-body-md hover:bg-accent-600 transition-colors duration-200 motion-reduce:transition-none focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2 cursor-pointer"
          aria-label="Call us on 0449 915 712"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.59 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          Call 0449 915 712
        </a>
        <a
          href="#contact"
          class="inline-flex items-center justify-center rounded-pill border border-secondary-300 text-surface px-7 py-3.5 font-body font-semibold text-body-md hover:bg-white/10 transition-colors duration-200 motion-reduce:transition-none focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2 cursor-pointer"
        >
          Send a message
        </a>
      </div>
    </div>
  </div>

  <!-- Service areas band -->
  <section class="py-16 bg-background" aria-labelledby="areas-heading">
    <div class="max-w-container mx-auto px-6 md:px-10 text-center">
      <p class="font-body text-label text-text-muted tracking-widest uppercase mb-4">Where we work</p>
      <h2 id="areas-heading" class="font-display text-heading-xl text-text-base mb-6">Service areas</h2>
      <p class="font-body text-body-lg text-text-muted max-w-2xl mx-auto mb-10">
        We're based in Melbourne and service the inner south-east and the Mornington Peninsula. Not sure if you're in our area? Just ask — we'll let you know.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        {[
          'Armadale', 'Toorak', 'Malvern', 'South Yarra', 'Prahran',
          'Brighton', 'Hawthorn', 'Camberwell', 'Kew', 'Canterbury',
          'Balwyn', 'Caulfield', 'Glen Iris', 'Mornington Peninsula',
          'Mt Eliza', 'Frankston',
        ].map(suburb => (
          <span class="rounded-pill bg-primary-100 text-primary font-body text-body-sm px-4 py-2">
            {suburb}
          </span>
        ))}
      </div>
    </div>
  </section>

  <ContactCta />
  <Footer />
</Layout>
