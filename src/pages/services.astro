---
import Layout        from '../layouts/Layout.astro';
import SmoothScroll  from '../components/SmoothScroll.astro';
import Nav           from '../components/Nav.astro';
import Services      from '../components/Services.astro';
import BeforeAfter   from '../components/BeforeAfter.astro';
import ContactCta    from '../components/ContactCta.astro';
import Footer        from '../components/Footer.astro';
import { Image }     from 'astro:assets';
import img8          from '../assets/images/img_8.jpg';
---

<Layout
  title="Garden Services Melbourne | Leo's Beautiful Gardens"
  description="Expert garden maintenance, pruning, hedge management, landscaping, pressure cleaning and pre-sale prep across Melbourne. Fourth-generation craft. Free quotes."
>
  <SmoothScroll />

  <Nav transparent={false} />

  <!-- Page hero -->
  <div class="relative py-24 md:py-32 bg-primary overflow-hidden">
    <Image
      src={img8}
      alt="Manicured parterre garden at a grand Melbourne mansion"
      width={1920}
      height={600}
      class="absolute inset-0 w-full h-full object-cover opacity-20"
      loading="eager"
    />
    <div class="relative max-w-container mx-auto px-6 md:px-10 text-center">
      <p class="font-body text-label text-secondary-400 tracking-widest uppercase mb-4">What we offer</p>
      <h1 class="font-display text-display-lg text-surface max-w-2xl mx-auto">
        Every service your garden needs, delivered with craft.
      </h1>
      <p class="font-body text-body-lg text-secondary-200 max-w-xl mx-auto mt-5">
        From fortnightly maintenance to full renovations — one trusted, skilled team across Melbourne.
      </p>
    </div>
  </div>

  <Services />
  <BeforeAfter />
  <ContactCta />
  <Footer />
</Layout>
