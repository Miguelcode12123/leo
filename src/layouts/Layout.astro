---
import '../styles/globals.css';
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import PreloadGallery from '../components/PreloadGallery.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  heroDesktopImage?: ImageMetadata;
  heroMobileImage?: ImageMetadata;
  preloadGallery?: boolean;
}

const {
  title       = "Leo's Beautiful Gardens | Premium Garden Care Melbourne",
  description = "Expert, design-led garden care across Melbourne — pruning, hedging, planting & renewal by a fourth-generation gardening family. Free quotes.",
  ogImage     = "/og-image.jpg",
  ogType      = "website",
  canonicalUrl = Astro.url.href,
  heroDesktopImage,
  heroMobileImage,
  preloadGallery = false,
} = Astro.props;

const heroPreloadSizes = '100vw';
const heroDesktopWidths = [1280, 1600, 1920, 2400, 2880];
const heroMobileWidths = [480, 640, 828, 1080, 1280];
const heroPreloadQuality = 92;
const [heroDesktopPreload, heroMobilePreload] = heroDesktopImage && heroMobileImage
  ? await Promise.all([
      getImage({
        src: heroDesktopImage,
        widths: heroDesktopWidths,
        sizes: heroPreloadSizes,
        quality: heroPreloadQuality,
        format: 'avif',
      }),
      getImage({
        src: heroMobileImage,
        widths: heroMobileWidths,
        sizes: heroPreloadSizes,
        quality: heroPreloadQuality,
        format: 'avif',
      }),
    ])
  : [null, null];

const siteUrl = "https://www.leosgardens.com.au";
const fontStylesheetHref = "https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,300;1,9..144,400&family=Mulish:wght@400;500;600;700&display=swap";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Leo's Beautiful Gardens",
  "image": `${siteUrl}/og-image.jpg`,
  "url": siteUrl,
  "telephone": "+61449915712",
  "email": "bookings@leosgardens.com.au",
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Melbourne",
    "addressRegion": "VIC",
    "addressCountry": "AU"
  },
  "areaServed": [
    "Melbourne", "Armadale", "Toorak", "Malvern", "Brighton",
    "Hawthorn", "Camberwell", "Mornington Peninsula"
  ],
  "sameAs": [
    "https://www.instagram.com/leos_beautiful_gardens/"
  ],
  "openingHours": "<!-- client to confirm -->"
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- ─── Primary SEO ──────────────────────────────────────────────────── -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- ─── Open Graph ───────────────────────────────────────────────────── -->
    <meta property="og:type"        content={ogType} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={`${siteUrl}${ogImage}`} />
    <meta property="og:url"         content={canonicalUrl} />
    <meta property="og:site_name"   content="Leo's Beautiful Gardens" />

    <!-- ─── Twitter Card ─────────────────────────────────────────────────── -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={`${siteUrl}${ogImage}`} />

    <!-- ─── Favicon ──────────────────────────────────────────────────────── -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon"     href="/apple-touch-icon.png" />

    <!-- ─── Google Fonts ─────────────────────────────────────────────────── -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href={fontStylesheetHref}
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link href={fontStylesheetHref} rel="stylesheet" />
    </noscript>

    {heroDesktopPreload && (
      <link
        rel="preload"
        as="image"
        href={heroDesktopPreload.src}
        imagesrcset={heroDesktopPreload.srcSet.attribute}
        imagesizes={heroPreloadSizes}
        media="(min-width: 768px)"
        type="image/avif"
        fetchpriority="high"
      />
    )}
    {heroMobilePreload && (
      <link
        rel="preload"
        as="image"
        href={heroMobilePreload.src}
        imagesrcset={heroMobilePreload.srcSet.attribute}
        imagesizes={heroPreloadSizes}
        media="(max-width: 767px)"
        type="image/avif"
        fetchpriority="high"
      />
    )}

    {preloadGallery && <PreloadGallery />}

    <!-- ─── Structured Data (LocalBusiness) ──────────────────────────────── -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body>
    <slot />
  </body>
</html>
